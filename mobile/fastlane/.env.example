# Copy to fastlane/.env (gitignored) and fill in. fastlane auto-loads it.

# App Store Connect API key (Users and Access → Integrations → App Store Connect API)
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# fastlane match — the SHARED private certs repo (same repo as kelu/specrgb/bettertaste)
MATCH_GIT_URL=git@github.com:you/apple-certs.git
MATCH_PASSWORD=your-match-encryption-passphrase

# Optional override (defaults to 2AMB7W8PVR):
# FASTLANE_TEAM_ID=2AMB7W8PVR
