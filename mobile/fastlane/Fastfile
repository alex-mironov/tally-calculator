# Tally — mobile (Expo / React Native), iOS only. App Store distribution via TestFlight.
#
#   bundle exec fastlane ios certificates   # one-time / when certs change (writes to match repo)
#   bundle exec fastlane ios beta           # prebuild + build + upload to TestFlight
#
# Signing: fastlane match (certs/profiles in a private git repo shared by every app
# on team 2AMB7W8PVR — app.kelu, app.specrgb, cc.bettertaste). The team has ONE
# Apple Distribution cert reused by all apps; `certificates` only adds THIS app's
# App Store profile, it NEVER regenerates the cert (that would revoke signing for
# the other apps). Auth: App Store Connect API key. Requires fastlane/.env
# (see fastlane/.env.example and DISTRIBUTION.md).
#
# NOTE: mobile/ios is NOT committed — it's regenerated by `expo prebuild` (CNG).
# The beta lane runs prebuild itself; its manual-signing edit lives only in that
# throwaway generated project.

default_platform(:ios)

APP_IDENTIFIER = "app.tally-calculator"
XCODEPROJ = "ios/Tally.xcodeproj"
WORKSPACE = "ios/Tally.xcworkspace"
SCHEME = "Tally"

platform :ios do
  before_all do
    %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_PATH MATCH_GIT_URL MATCH_PASSWORD].each do |k|
      UI.user_error!("Missing #{k} — copy fastlane/.env.example to fastlane/.env and fill it in (see DISTRIBUTION.md).") if ENV[k].to_s.empty?
    end
  end

  desc "Add/refresh THIS app's App Store profile in the shared match repo"
  lane :certificates do
    # readonly:false so match creates the app.tally-calculator profile against the
    # shared team cert. It reuses the existing Apple Distribution cert — never mints
    # a new one. Run once when bootstrapping this app (or after a team cert nuke).
    match(app_identifier: APP_IDENTIFIER, api_key: asc_api_key, readonly: false)
  end

  desc "Enable the iCloud (key-value storage) capability on this app's App ID"
  lane :enable_icloud do
    # produce's portal path still demands an Apple ID, so drive the App Store
    # Connect API directly with the key instead (no Apple ID needed). "XCODE_5" is
    # legacy iCloud = key-value storage + Documents — what NSUbiquitousKeyValueStore
    # needs, without CloudKit. Idempotent: skips if it's already on. This only
    # touches app.tally-calculator's App ID; it never affects the shared cert.
    require "spaceship"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      filepath: File.expand_path(ENV.fetch("ASC_KEY_PATH")),
    )
    Spaceship::ConnectAPI.token = token

    bundle_id = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_IDENTIFIER }
    UI.user_error!("App ID #{APP_IDENTIFIER} not found on the portal") if bundle_id.nil?

    caps = Spaceship::ConnectAPI::BundleIdCapability::Type
    settings = Spaceship::ConnectAPI::BundleIdCapability::Settings
    options = Spaceship::ConnectAPI::BundleIdCapability::Options

    already = bundle_id.get_capabilities.any? { |c| c.capability_type == caps::ICLOUD }
    if already
      UI.success("iCloud is already enabled on #{APP_IDENTIFIER} — nothing to do.")
    else
      bundle_id.create_capability(
        caps::ICLOUD,
        settings: [{
          key: settings::ICLOUD_VERSION,
          options: [{ key: options::XCODE_5 }],
        }],
      )
      UI.success("Enabled iCloud (key-value storage) on #{APP_IDENTIFIER}.")
    end
    UI.message("Next: bundle exec fastlane ios certificates  (regenerates the profile with the new entitlement)")
  end

  desc "Regenerate the native iOS project from the Expo config (CNG)"
  lane :prebuild do
    # `sh` runs inside ./fastlane, so step up to the mobile/ project root.
    sh("cd .. && npx expo prebuild --platform ios --clean")
  end

  desc "Build and upload an iOS build to TestFlight"
  lane :beta do
    key = asc_api_key

    prebuild
    # Read-only: pull the shared team cert + this app's profile from the match repo.
    match(app_identifier: APP_IDENTIFIER, api_key: key)
    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING][APP_IDENTIFIER]

    # Generated project defaults to automatic signing — switch to the match profile.
    update_code_signing_settings(
      path: XCODEPROJ,
      use_automatic_signing: false,
      team_id: CredentialsManager::AppfileConfig.try_fetch_value(:team_id),
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: [SCHEME],
    )

    build = latest_testflight_build_number(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0,
    ) + 1
    increment_build_number(build_number: build, xcodeproj: XCODEPROJ)

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name,
        },
      },
    )

    upload_to_testflight(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
    )

    UI.success("Uploaded iOS build #{build} to TestFlight 🚀")
  end

  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house: false,
    )
  end
end
